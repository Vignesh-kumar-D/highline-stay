# Copy this to `.env.local` for local frontend dev (vite picks it up).
# Locally you can leave it empty; vite proxies /api -> http://127.0.0.1:8787 (the worker).

# In production, set this to your deployed Cloudflare Worker base URL, e.g.
# VITE_API_BASE_URL=https://highline-stay-api.your-subdomain.workers.dev
VITE_API_BASE_URL=
