# Copy this to `.env.local` for local frontend dev (vite picks it up).
# Locally you can leave it empty; vite proxies /api -> http://127.0.0.1:8787 (the worker).

# Resend / OTP secrets are NOT read from here — the Worker ignores Vite dotenv files.
# Put RESEND_API_KEY and OTP_PEPPER in `.dev.vars` (see .dev.vars.example) for wrangler dev,
# or `wrangler secret put ...` on the deployed Worker.

# In production, set this to your deployed Cloudflare Worker base URL only if UI and API
# are on different hosts; leave empty when the SPA is served by the same Worker (assets).
# VITE_API_BASE_URL=https://highline-stay-api.your-subdomain.workers.dev
VITE_API_BASE_URL=
