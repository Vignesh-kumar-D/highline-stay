# Copy this file to `.dev.vars` for local `wrangler dev`.
# `.dev.vars` is gitignored. Do NOT commit real secrets.

# SendGrid HTTP API key with at least "Mail Send" permission.
SENDGRID_API_KEY=SG.replace-me

# Random string used as pepper when hashing OTP codes. Use a long random value.
OTP_PEPPER=replace-with-long-random-string
